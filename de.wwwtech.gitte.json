{
  "id": "de.wwwtech.gitte",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "gitte",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--socket=ssh-auth",
    "--filesystem=home"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_NET_OFFLINE": "true"
    }
  },
  "modules": [
    {
      "name": "gitte",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://codeberg.org/ckruse/Gitte.git",
          "tag": "0.1.10",
          "commit": "d664d637913485dafa0939554874a66f8c85eb1e"
        },
        "cargo-sources.json"
      ],
      "config-opts": ["-Dcargo-home=/run/build/gitte/cargo"]
    }
  ]
}
